import { LineEdit, Button, CheckBox, VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";

export struct ReminderItem {
    id: string,
    title: string,
    time: string,
    is_repeating: bool,
}

export component EditorWindow inherits Window {
    width: 480px;
    height: 600px;
    title: "Manage Reminders";
    background: @linear-gradient(135deg, #13141f, #1b1e2e, #111322);
    icon: @image-url("../assets/icon.png");

    in property <[ReminderItem]> reminders: [];
    in property <string> error_message: "";
    in-out property <string> default_date: "";
    in-out property <string> default_time: "";
    
    callback save_task(string, string, string, string, bool, string);
    callback delete_task(string);
    callback cancel();
    
    VerticalBox {
        padding: 20px;
        spacing: 12px;

        // Header Section
        HorizontalBox {
            padding: 0;
            alignment: space-between;
            Text {
                text: "Your Reminders";
                font-size: 18px;
                font-weight: 700;
                color: #e94560;
                vertical-alignment: center;
            }
            
            Text {
                text: root.reminders.length + " active";
                font-size: 13px;
                color: #94a3b8;
                vertical-alignment: center;
            }
        }

        // List Scroll Container with styled items
        Rectangle {
            background: #1e2235;
            border-radius: 8px;
            border-width: 1px;
            border-color: #2b3045;
            height: 140px;
            clip: true;

            ScrollView {
                VerticalBox {
                    padding: 8px;
                    alignment: start;
                    spacing: 8px;
                    for reminder in root.reminders : Rectangle {
                        background: #181a28;
                        border-radius: 6px;
                        height: 38px;
                        
                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 8px;
                            
                            Text {
                                text: reminder.title;
                                color: white;
                                font-size: 13px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }
                            
                            Text {
                                text: "@ " + reminder.time;
                                color: #a9b0c0;
                                font-size: 12px;
                                vertical-alignment: center;
                            }

                            if reminder.is_repeating : Text {
                                text: "🔁";
                                font-size: 12px;
                                vertical-alignment: center;
                            }

                            // Spacer to push delete button to the right
                            Rectangle {}

                            Button {
                                text: "❌";
                                width: 28px;
                                height: 28px;
                                clicked => {
                                    root.delete_task(reminder.id);
                                }
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: #ffffff1f;
        }

        // Section Form
        Text {
            text: "Create New Reminder";
            font-size: 16px;
            font-weight: 700;
            color: #e94560;
        }

        // Input: Title
        VerticalBox {
            padding: 0;
            spacing: 4px;
            Text { text: "Title"; color: #a9b0c0; font-size: 12px; font-weight: 600; }
            title_input := LineEdit { placeholder-text: "e.g., Drink Water"; height: 35px; }
        }

        // Input: Message
        VerticalBox {
            padding: 0;
            spacing: 4px;
            Text { text: "Message / Task Details"; color: #a9b0c0; font-size: 12px; font-weight: 600; }
            message_input := LineEdit { placeholder-text: "e.g., Take a 5 min break"; height: 35px; }
        }

        // Input: Date & Time in a row
        HorizontalBox {
            padding: 0;
            spacing: 12px;
            
            VerticalBox {
                padding: 0;
                spacing: 4px;
                Text { text: "Date (YYYY-MM-DD)"; color: #a9b0c0; font-size: 12px; font-weight: 600; }
                date_input := LineEdit { text: root.default_date; placeholder-text: "YYYY-MM-DD"; height: 35px; }
            }
            
            VerticalBox {
                padding: 0;
                spacing: 4px;
                Text { text: "Time (HH:MM)"; color: #a9b0c0; font-size: 12px; font-weight: 600; }
                time_input := LineEdit { text: root.default_time; placeholder-text: "14:30"; height: 35px; }
            }
        }

        // Input: Repeat config
        HorizontalBox {
            padding: 0;
            spacing: 12px;
            alignment: space-between;
            
            repeat_check := CheckBox {
                text: "Repeat Interval";
            }
            
            HorizontalBox {
                padding: 0;
                spacing: 4px;
                alignment: end;
                
                repeat_interval := LineEdit {
                    text: "60";
                    placeholder-text: "mins";
                    enabled: repeat_check.checked;
                    width: 70px;
                    height: 35px;
                }
                Text {
                    text: "minutes";
                    color: #a9b0c0;
                    font-size: 12px;
                    vertical-alignment: center;
                }
            }
        }
        
        if root.error_message != "" : Text {
            text: root.error_message;
            color: #ff5555;
            font-size: 12px;
            horizontal-alignment: center;
        }

        // Bottom buttons row
        HorizontalBox {
            alignment: center;
            spacing: 16px;
            padding-top: 10px;
            
            Button {
                text: "Cancel";
                width: 100px;
                height: 36px;
                clicked => { root.cancel(); }
            }
            
            Button {
                text: "Save Task";
                primary: true;
                width: 120px;
                height: 36px;
                clicked => {
                    root.save_task(
                        title_input.text,
                        message_input.text,
                        date_input.text,
                        time_input.text,
                        repeat_check.checked,
                        repeat_interval.text
                    );
                }
            }
        }
    }
}
